{
  "name": "launchpad-commerce",
  "version": "0.1.0",
  "description": "A production-ready e-commerce platform built with Next.js, Stripe, and PostgreSQL. Portfolio project demonstrating full-stack development expertise.",
  "author": {
    "name": "Luiz Spinelli",
    "url": "https://spinelli.dev.br"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luizspinelli/launchpad-commerce.git"
  },
  "bugs": {
    "url": "https://github.com/luizspinelli/launchpad-commerce/issues"
  },
  "homepage": "https://launchpad-commerce-roan.vercel.app",
  "keywords": [
    "e-commerce",
    "next.js",
    "stripe",
    "postgresql",
    "typescript",
    "full-stack",
    "portfolio"
  ],
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "seed": "tsx prisma/seed.ts",
    "setup-db": "tsx scripts/setup-db.ts",
    "postinstall": "prisma generate && npm run setup-db || echo 'Setup DB skipped (may need DATABASE_URL)'"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "clsx": "^2.0.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^3.0.0",
    "stripe": "^14.10.0",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^5.7.1",
    "tailwindcss": "^4",
    "tsx": "^4.7.0",
    "typescript": "^5"
  }
}
