# Stripe Configuration
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Public Stripe Key (for frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Resend Configuration (Optional - for transactional emails)
# Get this from https://resend.com
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@launchpad-commerce.com

# Application URLs
NEXT_PUBLIC_URL=http://localhost:3000

# Database (Vercel Postgres creates this automatically)
# For local development with PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/launchpad

# Optional: Development
NODE_ENV=development
